<%# Hero section %>
<section class="py-16 px-6 bg-blue-dark">
  <div class="max-w-2xl mx-auto text-center">
    <h1 class="text-3xl font-bold text-white md:text-4xl">Your results are ready!</h1>
    <p class="mt-4 text-base text-white opacity-90">
      Based on your answers, we've matched you with nonprofit organizations
      that best fit your needs. You can explore the options below to learn more
      and take the next step.
    </p>
  </div>
</section>

<%# Results section %>
<section class="py-12 px-6 bg-gray-9">
  <div class="max-w-4xl mx-auto">
    <% if @embedding_unavailable %>
      <div class="p-12 text-center bg-white rounded-lg shadow-md">
        <div class="flex justify-center mb-6">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-20 h-20 text-gray-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z" />
          </svg>
        </div>
        <h2 class="mb-2 text-xl font-bold text-gray-2">Smart Match is temporarily unavailable</h2>
        <p class="mb-6 text-gray-4">
          Our matching engine is currently offline. Please try again in a few minutes.
        </p>
        <%= link_to "Try Again",
              smart_match_results_path,
              class: "inline-block px-8 py-3 font-bold text-white uppercase rounded-md bg-salmon hover:bg-salmon-medium transition-colors" %>
      </div>

    <% elsif @results.present? %>
      <div class="space-y-8">
        <% @results.each do |match| %>
          <%= render SmartMatchCard::Component.new(
                organization: match.organization,
                match: match,
                user_type: @user_type
              ) %>
        <% end %>
      </div>

      <div class="mt-10 text-center">
        <%= link_to "Retake Quiz",
              smart_match_quiz_path,
              class: "text-blue-dark font-bold underline hover:text-blue-medium transition-colors" %>
        <hr class="mt-6 border-gray-6">
      </div>

    <% else %>
      <div class="p-12 text-center bg-white rounded-lg shadow-md">
        <div class="flex justify-center mb-6">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-20 h-20 text-gray-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z" />
          </svg>
        </div>
        <h2 class="mb-2 text-xl font-bold text-gray-2">No quiz results found</h2>
        <p class="mb-6 text-gray-4">
          Take the quiz to get personalized nonprofit matches.
        </p>
        <%= link_to "Take the Quiz",
              smart_match_quiz_path,
              class: "inline-block px-8 py-3 font-bold text-white uppercase rounded-md bg-salmon hover:bg-salmon-medium transition-colors" %>
      </div>
    <% end %>
  </div>
</section>
