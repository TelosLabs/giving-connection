<%= form_with url: smart_match_quiz_path, method: :put, id: "quiz-form",
             data: { smart_match_quiz_target: "form" } do |f| %>
  <div class="grid gap-4 mt-4 sm:grid-cols-3" data-card-group="user-type">
    <% [
      ["service_seeker", "Find Services", "I'm looking for nonprofit services in my area",
       "M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z"],
      ["volunteer", "Volunteer", "I want to give my time to a cause I care about",
       "M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 018.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0111.964-3.07M12 6.375a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zm8.25 2.25a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0z"],
      ["donor", "Donate", "I want to support organizations financially",
       "M21 11.25v8.25a1.5 1.5 0 01-1.5 1.5H5.25a1.5 1.5 0 01-1.5-1.5v-8.25M12 4.875A2.625 2.625 0 109.375 7.5H12m0-2.625V7.5m0-2.625A2.625 2.625 0 1114.625 7.5H12m0 0V21m-8.625-9.75h18c.621 0 1.125-.504 1.125-1.125v-1.5c0-.621-.504-1.125-1.125-1.125h-18c-.621 0-1.125.504-1.125 1.125v1.5c0 .621.504 1.125 1.125 1.125z"]
    ].each do |value, label, description, icon_path| %>
      <label class="sm-card-option"
             data-action="click->smart-match-quiz#selectCard"
             data-select-mode="single">
        <%= f.radio_button :user_type, value,
              class: "sr-only",
              data: { smart_match_quiz_target: "radio" } %>
        <div class="flex items-center justify-center w-16 h-16 rounded-full bg-white/60">
          <svg class="w-9 h-9" fill="none" viewBox="0 0 24 24" stroke="#113C7B" stroke-width="1.5" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="<%= icon_path %>" />
          </svg>
        </div>
        <span class="text-base font-bold text-gray-2"><%= label %></span>
        <p class="text-sm text-gray-4"><%= description %></p>
      </label>
    <% end %>
  </div>
<% end %>
