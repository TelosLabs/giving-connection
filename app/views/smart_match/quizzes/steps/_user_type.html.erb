<%= form_with url: smart_match_quiz_path, method: :put, id: "quiz-form",
             data: { smart_match_quiz_target: "form" } do |f| %>
  <div class="grid gap-4 mt-4 sm:grid-cols-3" data-card-group="user-type">

    <%# Service seeker %>
    <label class="sm-card-option bg-white"
           data-action="click->smart-match-quiz#selectCard"
           data-select-mode="single">
      <%= f.radio_button :user_type, "service_seeker",
            class: "sr-only",
            data: { smart_match_quiz_target: "radio" } %>
      <span class="text-base font-bold text-gray-2">I'm here seeking help from a nonprofit</span>
      <%= image_tag "cloud-laptop.svg", class: "w-2/3 max-w-md h-auto", alt: "Service seeker" %>
    </label>

    <%# Donor %>
    <label class="sm-card-option bg-white"
           data-action="click->smart-match-quiz#selectCard"
           data-select-mode="single">
      <%= f.radio_button :user_type, "donor",
            class: "sr-only",
            data: { smart_match_quiz_target: "radio" } %>
      <span class="text-base font-bold text-gray-2">I want to donate to a cause I care about</span>
      <%= image_tag "e-commerce.svg", class: "w-2/3 max-w-md h-auto", alt: "Donor" %>
    </label>

    <%# Volunteer %>
    <label class="sm-card-option bg-white"
           data-action="click->smart-match-quiz#selectCard"
           data-select-mode="single">
      <%= f.radio_button :user_type, "volunteer",
            class: "sr-only",
            data: { smart_match_quiz_target: "radio" } %>
      <span class="text-base font-bold text-gray-2">I want to volunteer my time</span>
      <%= image_tag "water-plants.svg", class: "w-2/3 max-w-md h-auto", alt: "Volunteer" %>
    </label>

  </div>
<% end %>
