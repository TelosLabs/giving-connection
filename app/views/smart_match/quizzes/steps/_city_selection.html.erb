<%= form_with url: smart_match_quiz_path, method: :put, id: "quiz-form",
             data: { smart_match_quiz_target: "form" } do |f| %>
  <div data-card-group="city-selection" data-card-cols="3">

    <% [
      ["Atlantic City", "Atlantic City", "smart_match/atlantic_city.svg"],
      ["Los Angeles",   "Los Angeles",   "smart_match/california.svg"],
      ["Nashville",     "Nashville",     "smart_match/nashville.svg"]
    ].each do |label, value, icon| %>
      <label class="sm-card-option sm-card-option--blue <%= 'selected' if @session_answers[:city] == value %>"
             data-action="click->smart-match-quiz#selectCard"
             data-select-mode="single">
        <%= f.radio_button :city_selection, value,
              class: "sr-only",
              checked: @session_answers[:city] == value,
              data: { smart_match_quiz_target: "radio" } %>
        <span class="text-base font-bold"><%= label %></span>
        <%= inline_svg_tag icon, class: "w-24 h-24 mt-2", aria_hidden: "true" %>
      </label>
    <% end %>

  </div>

  <div class="sm-selection-hint mt-5 rounded-lg px-5 py-3 text-sm font-medium text-blue-dark text-center" style="background-color: #e2ecf7;">
    Thanks for sharing this. You're moving closer to your personalized results.
  </div>
<% end %>
