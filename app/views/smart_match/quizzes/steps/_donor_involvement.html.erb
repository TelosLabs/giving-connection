<%= form_with url: smart_match_quiz_path, method: :put, id: "quiz-form",
             data: { smart_match_quiz_target: "form" } do |f| %>
  <div data-card-group="donor_involvement" data-card-cols="4">

    <% [
      ["Make a one-time donation",             "one_time_donation",  "smart_match/donation_hand.svg","text-blue-dark"],
      ["Learn more and receive updates",        "learn_updates",      "smart_match/alert2.svg",      "text-blue-dark"],
      ["Volunteer or attend events",            "volunteer_events",   "smart_match/teamwork.svg",    "text-blue-dark"],
      ["Explore ongoing or deeper involvement", "deeper_involvement", "smart_match/recurrent.svg",   "text-blue-dark"]
    ].each do |label, value, icon, icon_class| %>
      <label class="sm-card-option <%= 'selected' if @session_answers[:donor_involvement] == value %>"
             data-action="click->smart-match-quiz#selectCard"
             data-select-mode="single">
        <%= f.radio_button :donor_involvement, value,
              class: "sr-only",
              checked: @session_answers[:donor_involvement] == value,
              data: { smart_match_quiz_target: "radio" } %>
        <span class="text-base font-bold text-center"><%= label %></span>
        <%= inline_svg_tag icon, class: "w-20 h-20 mt-2 #{icon_class}", aria_hidden: "true" %>
      </label>
    <% end %>

  </div>
<% end %>
