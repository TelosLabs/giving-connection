<%= form_with url: smart_match_quiz_path, method: :put, id: "quiz-form",
             data: { smart_match_quiz_target: "form" } do |f| %>
  <p class="mb-6 text-sm text-center text-gray-4">
    Sharing this information is optional and only helps us improve the relevance of certain results.
    You may choose "Prefer not to say" in any question.
  </p>

  <div class="max-w-md mx-auto space-y-6">

    <div>
      <%= f.label :age_range, "Age Range", class: "block mb-1 text-sm font-semibold text-gray-2" %>
      <%= f.select :age_range,
            options_for_select([
              ["Under 18",          "under_18"],
              ["19–24",             "19_24"],
              ["25–34",             "25_34"],
              ["35–44",             "35_44"],
              ["45–54",             "45_54"],
              ["55–64",             "55_64"],
              ["Over 65+",          "over_65"],
              ["Prefer not to say", "prefer_not_to_say"]
            ], session[:smart_match_age_range]),
            { include_blank: "Select your age range" },
            class: "w-full px-4 py-3 text-gray-2 border border-gray-5 rounded-md focus:border-blue-medium focus:ring-1 focus:ring-blue-medium focus:outline-none",
            data: { action: "change->smart-match-quiz#updateNextButton" } %>
    </div>

    <div>
      <%= f.label :gender_identity, "Gender Identity", class: "block mb-1 text-sm font-semibold text-gray-2" %>
      <%= f.select :gender_identity,
            options_for_select([
              ["Female",                       "female"],
              ["Male",                         "male"],
              ["Non-binary or gender diverse", "non_binary"],
              ["Other",                        "other"],
              ["Prefer not to say",            "prefer_not_to_say"]
            ], session[:smart_match_gender_identity]),
            { include_blank: "Select your gender identity" },
            class: "w-full px-4 py-3 text-gray-2 border border-gray-5 rounded-md focus:border-blue-medium focus:ring-1 focus:ring-blue-medium focus:outline-none",
            data: { action: "change->smart-match-quiz#updateNextButton" } %>
    </div>

    <div>
      <%= f.label :race_ethnicity, "Race or Ethnicity", class: "block mb-1 text-sm font-semibold text-gray-2" %>
      <%= f.select :race_ethnicity,
            options_for_select([
              ["Black or African American",            "black_african_american"],
              ["Hispanic or Latino/a/x",               "hispanic_latino"],
              ["White",                                "white"],
              ["Asian",                                "asian"],
              ["Native American or Alaska Native",     "native_american"],
              ["Native Hawaiian or Pacific Islander",  "native_hawaiian"],
              ["Middle Eastern or North African",      "middle_eastern_north_african"],
              ["Prefer not to say",                    "prefer_not_to_say"]
            ], session[:smart_match_race_ethnicity]),
            { include_blank: "Select your race or ethnicity" },
            class: "w-full px-4 py-3 text-gray-2 border border-gray-5 rounded-md focus:border-blue-medium focus:ring-1 focus:ring-blue-medium focus:outline-none",
            data: { action: "change->smart-match-quiz#updateNextButton" } %>
    </div>

  </div>
<% end %>
