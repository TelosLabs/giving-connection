<%= form_with url: smart_match_quiz_path, method: :put, id: "quiz-form",
             data: { smart_match_quiz_target: "form" } do |f| %>
  <div class="max-w-md mt-4 space-y-6">
    <div>
      <%= f.label :language_input,
            "Describe what you're looking for (optional)",
            class: "block mb-1 text-sm font-semibold text-gray-2" %>
      <p class="mb-2 text-sm text-gray-4">
        This helps us find the best match. Be as specific or general as you'd like.
      </p>
      <%= f.text_area :language_input,
            value: session[:smart_match_language],
            placeholder: "E.g., I need help finding affordable childcare near downtown...",
            rows: 5,
            class: "w-full px-4 py-3 text-gray-2 border border-gray-5 rounded-md focus:border-blue-medium focus:ring-1 focus:ring-blue-medium focus:outline-none resize-none" %>
    </div>
  </div>
<% end %>
