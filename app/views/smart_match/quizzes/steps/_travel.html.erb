<%= form_with url: smart_match_quiz_path, method: :put, id: "quiz-form",
             data: { smart_match_quiz_target: "form" } do |f| %>
  <div data-card-group="travel" data-card-cols="4">

    <%# Walking distance %>
    <label class="sm-card-option sm-card-option--white <%= 'selected' if @session_answers[:travel_bucket] == 'nearby' %>"
           data-action="click->smart-match-quiz#selectCard"
           data-select-mode="single">
      <%= f.radio_button :travel_bucket, "nearby",
            class: "sr-only",
            checked: @session_answers[:travel_bucket] == "nearby",
            data: { smart_match_quiz_target: "radio" } %>
      <span class="text-base font-bold text-center"><%= t("smart_match.quiz.steps.travel.options.nearby") %></span>
      <%= inline_svg_tag "smart_match/person.svg", class: "w-20 h-20 mt-2", aria_hidden: "true" %>
    </label>

    <%# Public transit %>
    <label class="sm-card-option sm-card-option--white <%= 'selected' if @session_answers[:travel_bucket] == 'moderate' %>"
           data-action="click->smart-match-quiz#selectCard"
           data-select-mode="single">
      <%= f.radio_button :travel_bucket, "moderate",
            class: "sr-only",
            checked: @session_answers[:travel_bucket] == "moderate",
            data: { smart_match_quiz_target: "radio" } %>
      <span class="text-base font-bold text-center"><%= t("smart_match.quiz.steps.travel.options.moderate") %></span>
      <%= inline_svg_tag "smart_match/bus.svg", class: "w-20 h-20 mt-2", aria_hidden: "true" %>
    </label>

    <%# Car or ride share %>
    <label class="sm-card-option sm-card-option--white <%= 'selected' if @session_answers[:travel_bucket] == 'far' %>"
           data-action="click->smart-match-quiz#selectCard"
           data-select-mode="single">
      <%= f.radio_button :travel_bucket, "far",
            class: "sr-only",
            checked: @session_answers[:travel_bucket] == "far",
            data: { smart_match_quiz_target: "radio" } %>
      <span class="text-base font-bold text-center"><%= t("smart_match.quiz.steps.travel.options.far") %></span>
      <%= inline_svg_tag "smart_match/car.svg", class: "w-20 h-20 mt-2", aria_hidden: "true" %>
    </label>

    <%# Remote only %>
    <label class="sm-card-option sm-card-option--white <%= 'selected' if @session_answers[:travel_bucket] == 'statewide' %>"
           data-action="click->smart-match-quiz#selectCard"
           data-select-mode="single">
      <%= f.radio_button :travel_bucket, "statewide",
            class: "sr-only",
            checked: @session_answers[:travel_bucket] == "statewide",
            data: { smart_match_quiz_target: "radio" } %>
      <span class="text-base font-bold text-center"><%= t("smart_match.quiz.steps.travel.options.statewide") %></span>
      <%= inline_svg_tag "smart_match/building.svg", class: "w-20 h-20 mt-2", aria_hidden: "true" %>
    </label>

  </div>
  <div class="sm-selection-hint mt-5 rounded-lg px-5 py-3 text-sm font-medium text-blue-dark text-center" style="background-color: #e2ecf7;">
    <%= t("smart_match.quiz.steps.travel.hint") %>
  </div>
<% end %>
