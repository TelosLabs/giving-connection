<%= form_with url: smart_match_quiz_path, method: :put, id: "quiz-form",
             data: { smart_match_quiz_target: "form" } do |f| %>
  <div data-card-group="travel" data-card-cols="4">

    <%# Walking distance %>
    <label class="sm-card-option sm-card-option--white"
           data-action="click->smart-match-quiz#selectCard"
           data-select-mode="single">
      <%= f.radio_button :travel_bucket, "walking",
            class: "sr-only",
            data: { smart_match_quiz_target: "radio" } %>
      <span class="text-base font-bold text-center">Walking distance only (under 5 miles)</span>
      <%= inline_svg_tag "smart_match/person.svg", class: "w-20 h-20 mt-2", aria_hidden: "true" %>
    </label>

    <%# Public transit %>
    <label class="sm-card-option sm-card-option--white"
           data-action="click->smart-match-quiz#selectCard"
           data-select-mode="single">
      <%= f.radio_button :travel_bucket, "transit",
            class: "sr-only",
            data: { smart_match_quiz_target: "radio" } %>
      <span class="text-base font-bold text-center">Public transit or rides (5–10 miles)</span>
      <%= inline_svg_tag "smart_match/bus.svg", class: "w-20 h-20 mt-2", aria_hidden: "true" %>
    </label>

    <%# Car or ride share %>
    <label class="sm-card-option sm-card-option--white"
           data-action="click->smart-match-quiz#selectCard"
           data-select-mode="single">
      <%= f.radio_button :travel_bucket, "car",
            class: "sr-only",
            data: { smart_match_quiz_target: "radio" } %>
      <span class="text-base font-bold text-center">Car or ride share available (10+ miles)</span>
      <%= inline_svg_tag "smart_match/car.svg", class: "w-20 h-20 mt-2", aria_hidden: "true" %>
    </label>

    <%# Remote only %>
    <label class="sm-card-option sm-card-option--white"
           data-action="click->smart-match-quiz#selectCard"
           data-select-mode="single">
      <%= f.radio_button :travel_bucket, "remote",
            class: "sr-only",
            data: { smart_match_quiz_target: "radio" } %>
      <span class="text-base font-bold text-center">Remote services only</span>
      <%= inline_svg_tag "smart_match/building.svg", class: "w-20 h-20 mt-2", aria_hidden: "true" %>
    </label>

  </div>
  <div class="sm-selection-hint mt-5 rounded-lg px-5 py-3 text-sm font-medium text-blue-dark text-center" style="background-color: #e2ecf7;">
    Thanks for sharing this. You're moving closer to your personalized results.
  </div>
<% end %>
