<%= form_with url: smart_match_quiz_path, method: :put, id: "quiz-form",
             data: { smart_match_quiz_target: "form" } do |f| %>
  <div class="grid gap-4 mt-4 sm:grid-cols-3" data-card-group="situation">

    <%# Urgent %>
    <label class="sm-card-option bg-red-400"
           data-action="click->smart-match-quiz#selectCard"
           data-select-mode="single">
      <%= f.radio_button :situation, "urgent",
            class: "sr-only",
            data: { smart_match_quiz_target: "radio" } %>
      <span class="text-base font-bold text-white">I need services urgently</span>
      <%= image_tag "smart_match/alert.svg", class: "w-2/3 max-w-md h-auto", alt: "I need services urgently" %>
    </label>

    <%# Long-term %>
    <label class="sm-card-option bg-red-400"
           data-action="click->smart-match-quiz#selectCard"
           data-select-mode="single">
      <%= f.radio_button :situation, "long_term",
            class: "sr-only",
            data: { smart_match_quiz_target: "radio" } %>
      <span class="text-base font-bold text-white">I am looking for long-term support</span>
      <%= image_tag "smart_match/time.svg", class: "w-2/3 max-w-md h-auto", alt: "I am looking for long-term support" %>
    </label>

    <%# Exploring %>
    <label class="sm-card-option bg-red-400"
           data-action="click->smart-match-quiz#selectCard"
           data-select-mode="single">
      <%= f.radio_button :situation, "exploring",
            class: "sr-only",
            data: { smart_match_quiz_target: "radio" } %>
      <span class="text-base font-bold text-white">I am exploring my options</span>
      <%= inline_svg_tag "smart_match/map.svg", class: "w-2/3 max-w-md h-auto text-white", alt: "I am exploring my options" %>
    </label>

  </div>
<% end %>
