<%
  selected_causes = @session_answers[:causes]

  causes = [
    ["Food security", "hunger_food_security.svg"],
    ["Housing & homelessness", "housing_homelessness.svg"],
    ["Mental health",  "mental_health.svg"],
    ["Disability advocacy", "disability_services.svg"],
    ["Financial assistance", "financial_assistance.svg"],
    ["Health care", "health.svg"],
    ["Employment or job training", "employment.svg"],
    ["Justice & legal services", "justice_legal_services.svg"],
    ["Support for my children or family", "children_family_services.svg"],
    ["Help for transportation", "transportation.svg"],
    ["LGBTQIA+", "pride.svg"],
    ["Veteran & military", "veteran_military.svg"]
  ]

  more_causes = [
    ["Advocacy", "advocacy.svg"],
    ["Animals", "animals.svg"],
    ["Art & Culture", "arts_culture.svg"],
    ["Clothing & living essentials", "clothing_living_essentials.svg"],
    ["Community & economic development", "community_economic_development.svg"],
    ["Drug & alcohol treatment", "drug_alcohol_treatment.svg"],
    ["Education", "education.svg"],
    ["Emergency & safety", "emergency_safety.svg"],
    ["Faith-based", "faith_based.svg"],
    ["Health", "health.svg"],
    ["Human & social services", "human_social_services.svg"],
    ["Immigrant & refugee", "immigrant_refugee.svg"],
    ["Inmate & formerly incarcerated", "inmate_formerly_incarcerated.svg"],
    ["International", "international.svg"],
    ["Media & broadcasting", "media_broadcasting.svg"],
    ["Philanthropy", "philanthropy.svg"],
    ["Race & ethnicity", "race_ethnicity.svg"],
    ["Research & public policy",  "research_public_policy.svg"],
    ["Science & technology", "science_technology.svg"],
    ["Seniors", "seniors.svg"],
    ["Social sciences", "social_sciences.svg"]
  ]

%>

<%= form_with url: smart_match_quiz_path, method: :put, id: "quiz-form",
              data: { smart_match_quiz_target: "form" } do |f| %>

  <%# Primary causes grid %>
  <div data-card-group="causes" data-card-cols="4">
    <% causes.each do |cause_name, icon_file| %>
      <label class="sm-card-option <%= 'selected' if selected_causes.include?(cause_name) %>"
             data-action="click->smart-match-quiz#selectCard"
             data-select-mode="multiple">
        <input type="checkbox"
               name="causes[]"
               value="<%= cause_name %>"
               class="sr-only"
               <%= "checked" if selected_causes.include?(cause_name) %>
               data-smart-match-quiz-target="causeCheckbox" />
        <span class="text-sm font-semibold leading-tight text-center"><%= cause_name %></span>
        <%= inline_svg_tag "causes_categories/#{icon_file}", class: "w-16 h-16 mt-2", aria_hidden: "true" %>
      </label>
    <% end %>
  </div>

  <%# Accordion: more causes %>
  <div class="mt-6">
    <button type="button"
            class="flex items-center gap-2 text-sm font-semibold cursor-pointer text-blue-dark hover:text-blue-medium"
            data-action="click->smart-match-quiz#toggleAccordion"
            data-smart-match-quiz-target="accordion">
      <span>Not finding a cause? More options here.</span>
      <svg class="w-4 h-4 transition-transform duration-200"
           data-smart-match-quiz-target="accordionIcon"
           fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
      </svg>
    </button>

    <div class="sm-category-accordion" data-smart-match-quiz-target="accordionContent">
      <div data-card-group="more-causes" data-card-cols="4">
        <% more_causes.each do |cause_name, icon_file| %>
          <label class="sm-card-option <%= 'selected' if selected_causes.include?(cause_name) %>"
                 data-action="click->smart-match-quiz#selectCard"
                 data-select-mode="multiple">
            <input type="checkbox"
                   name="causes[]"
                   value="<%= cause_name %>"
                   class="sr-only"
                   <%= "checked" if selected_causes.include?(cause_name) %>
                   data-smart-match-quiz-target="causeCheckbox" />
            <span class="text-sm font-semibold leading-tight text-center"><%= cause_name %></span>
            <%= inline_svg_tag "causes_categories/#{icon_file}", class: "w-16 h-16 mt-2", aria_hidden: "true" %>
          </label>
        <% end %>
      </div>
    </div>
  </div>

<% end %>
