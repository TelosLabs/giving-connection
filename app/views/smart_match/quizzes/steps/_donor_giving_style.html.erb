<%= form_with url: smart_match_quiz_path, method: :put, id: "quiz-form",
             data: { smart_match_quiz_target: "form" } do |f| %>
  <div data-card-group="donation_style" data-card-cols="3">

    <% [
      ["General donation",        "general_donation",  "smart_match/donate.svg",   ""],
      ["Support a specific project","specific_project","smart_match/goal.svg",     ""],
      ["Donate goods or items",   "goods_items",       "smart_match/groceries.svg",""],
      ["Set up recurring giving", "recurring_giving",  "smart_match/monthly.svg",  ""],
      ["Just exploring for now",  "just_exploring",    "smart_match/map.svg",      "text-white"]
    ].each do |label, value, icon, icon_class| %>
      <label class="sm-card-option sm-card-option--red <%= 'selected' if @session_answers[:donation_style].include?(value) %>"
             data-action="click->smart-match-quiz#selectCard"
             data-select-mode="multiple">
        <input type="checkbox" name="donation_style[]" value="<%= value %>"
               class="sr-only"
               <%= "checked" if @session_answers[:donation_style].include?(value) %>
               data-smart-match-quiz-target="causeCheckbox" />
        <span class="text-base font-bold text-center"><%= label %></span>
        <%= inline_svg_tag icon, class: "w-20 h-20 mt-2 #{icon_class}", aria_hidden: "true" %>
      </label>
    <% end %>

  </div>
<% end %>
