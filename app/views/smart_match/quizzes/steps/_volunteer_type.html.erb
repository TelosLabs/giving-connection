<%= form_with url: smart_match_quiz_path, method: :put, id: "quiz-form",
             data: { smart_match_quiz_target: "form" } do |f| %>
  <div data-card-group="volunteer_type" data-card-cols="4">

    <%# Kids or seniors %>
    <label class="sm-card-option"
           data-action="click->smart-match-quiz#selectCard"
           data-select-mode="multiple">
      <input type="checkbox" name="volunteer_type[]" value="kids_seniors"
             class="sr-only" data-smart-match-quiz-target="causeCheckbox" />
      <span class="text-base font-bold text-center">Kids or seniors</span>
      <%= inline_svg_tag "smart_match/elderly.svg", class: "w-20 h-20 mt-2", aria_hidden: "true" %>
    </label>

    <%# Veterans / military families %>
    <label class="sm-card-option"
           data-action="click->smart-match-quiz#selectCard"
           data-select-mode="multiple">
      <input type="checkbox" name="volunteer_type[]" value="veterans_military"
             class="sr-only" data-smart-match-quiz-target="causeCheckbox" />
      <span class="text-base font-bold text-center">Veterans / military families</span>
      <%= inline_svg_tag "causes_categories/veteran_military.svg", class: "w-20 h-20 mt-2", aria_hidden: "true" %>
    </label>

    <%# Spanish-speaking %>
    <label class="sm-card-option"
           data-action="click->smart-match-quiz#selectCard"
           data-select-mode="multiple">
      <input type="checkbox" name="volunteer_type[]" value="spanish_speaking"
             class="sr-only" data-smart-match-quiz-target="causeCheckbox" />
      <span class="text-base font-bold text-center">Spanish-speaking</span>
      <%= inline_svg_tag "smart_match/languages.svg", class: "w-20 h-20 mt-2 text-blue-dark", aria_hidden: "true" %>
    </label>

    <%# Grassroots / BIPOC-led %>
    <label class="sm-card-option"
           data-action="click->smart-match-quiz#selectCard"
           data-select-mode="multiple">
      <input type="checkbox" name="volunteer_type[]" value="grassroots_bipoc"
             class="sr-only" data-smart-match-quiz-target="causeCheckbox" />
      <span class="text-base font-bold text-center">Grassroots / BIPOC-led</span>
      <%= inline_svg_tag "smart_match/community.svg", class: "w-20 h-20 mt-2 text-blue-dark", aria_hidden: "true" %>
    </label>

    <%# Behind the scenes %>
    <label class="sm-card-option"
           data-action="click->smart-match-quiz#selectCard"
           data-select-mode="multiple">
      <input type="checkbox" name="volunteer_type[]" value="behind_scenes"
             class="sr-only" data-smart-match-quiz-target="causeCheckbox" />
      <span class="text-base font-bold text-center">Behind the scenes</span>
      <%= inline_svg_tag "smart_match/activities.svg", class: "w-20 h-20 mt-2 text-blue-dark", aria_hidden: "true" %>
    </label>

    <%# Accessible or virtual %>
    <label class="sm-card-option"
           data-action="click->smart-match-quiz#selectCard"
           data-select-mode="multiple">
      <input type="checkbox" name="volunteer_type[]" value="accessible_virtual"
             class="sr-only" data-smart-match-quiz-target="causeCheckbox" />
      <span class="text-base font-bold text-center">Accessible or virtual</span>
      <%= inline_svg_tag "smart_match/computer.svg", class: "w-20 h-20 mt-2 text-blue-dark", aria_hidden: "true" %>
    </label>

    <%# Family or group %>
    <label class="sm-card-option"
           data-action="click->smart-match-quiz#selectCard"
           data-select-mode="multiple">
      <input type="checkbox" name="volunteer_type[]" value="family_group"
             class="sr-only" data-smart-match-quiz-target="causeCheckbox" />
      <span class="text-base font-bold text-center">Family or group</span>
      <%= inline_svg_tag "smart_match/family.svg", class: "w-20 h-20 mt-2 text-blue-dark", aria_hidden: "true" %>
    </label>

    <%# No preference %>
    <label class="sm-card-option"
           data-action="click->smart-match-quiz#selectCard"
           data-select-mode="multiple">
      <input type="checkbox" name="volunteer_type[]" value="no_preference"
             class="sr-only" data-smart-match-quiz-target="causeCheckbox" />
      <span class="text-base font-bold text-center">No preference</span>
    </label>

  </div>

  <div class="sm-selection-hint mt-5 rounded-lg px-5 py-3 text-sm font-medium text-blue-dark text-center" style="background-color: #e2ecf7;">
    Your response helps us highlight volunteer opportunities that align with your interests and preferences.
  </div>
<% end %>
