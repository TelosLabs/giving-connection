<%= form_with url: smart_match_quiz_path, method: :put, id: "quiz-form",
             data: { smart_match_quiz_target: "form" } do |f| %>
  <div data-card-group="giving_inspiration" data-card-cols="4">

    <%# Supporting my local community %>
    <label class="sm-card-option sm-card-option--white"
           data-action="click->smart-match-quiz#selectCard"
           data-select-mode="multiple">
      <input type="checkbox" name="giving_inspiration[]" value="local_community"
             class="sr-only" data-smart-match-quiz-target="causeCheckbox" />
      <span class="text-base font-bold text-center">Supporting my local community</span>
      <%= inline_svg_tag "smart_match/community.svg", class: "w-20 h-20 mt-2 text-blue-dark", aria_hidden: "true" %>
    </label>

    <%# A cause that's personal or close to my heart %>
    <label class="sm-card-option sm-card-option--white"
           data-action="click->smart-match-quiz#selectCard"
           data-select-mode="multiple">
      <input type="checkbox" name="giving_inspiration[]" value="personal_cause"
             class="sr-only" data-smart-match-quiz-target="causeCheckbox" />
      <span class="text-base font-bold text-center">A cause that's personal or close to my heart</span>
      <%= inline_svg_tag "smart_match/user.svg", class: "w-20 h-20 mt-2 text-blue-dark", aria_hidden: "true" %>
    </label>

    <%# Helping underserved or overlooked communities %>
    <label class="sm-card-option sm-card-option--white"
           data-action="click->smart-match-quiz#selectCard"
           data-select-mode="multiple">
      <input type="checkbox" name="giving_inspiration[]" value="underserved_communities"
             class="sr-only" data-smart-match-quiz-target="causeCheckbox" />
      <span class="text-base font-bold text-center">Helping underserved or overlooked communities</span>
      <%= inline_svg_tag "smart_match/categories/care.svg", class: "w-20 h-20 mt-2 text-blue-dark", aria_hidden: "true" %>
    </label>

    <%# Giving in honor or in memory of someone %>
    <label class="sm-card-option sm-card-option--white"
           data-action="click->smart-match-quiz#selectCard"
           data-select-mode="multiple">
      <input type="checkbox" name="giving_inspiration[]" value="honor_memory"
             class="sr-only" data-smart-match-quiz-target="causeCheckbox" />
      <span class="text-base font-bold text-center">Giving in honor or in memory of someone</span>
      <%= inline_svg_tag "causes_categories/mental_health.svg", class: "w-20 h-20 mt-2", aria_hidden: "true" %>
    </label>

    <%# Making sure my donation has real impact %>
    <label class="sm-card-option sm-card-option--white"
           data-action="click->smart-match-quiz#selectCard"
           data-select-mode="multiple">
      <input type="checkbox" name="giving_inspiration[]" value="real_impact"
             class="sr-only" data-smart-match-quiz-target="causeCheckbox" />
      <span class="text-base font-bold text-center">Making sure my donation has real impact</span>
      <%= inline_svg_tag "causes_categories/financial_assistance.svg", class: "w-20 h-20 mt-2", aria_hidden: "true" %>
    </label>

    <%# Discovering meaningful ways to give %>
    <label class="sm-card-option sm-card-option--white"
           data-action="click->smart-match-quiz#selectCard"
           data-select-mode="multiple">
      <input type="checkbox" name="giving_inspiration[]" value="discovering_ways"
             class="sr-only" data-smart-match-quiz-target="causeCheckbox" />
      <span class="text-base font-bold text-center">Discovering meaningful ways to give</span>
      <%= inline_svg_tag "smart_match/map.svg", class: "w-20 h-20 mt-2 text-blue-dark", aria_hidden: "true" %>
    </label>

    <%# Giving in alignment with my values %>
    <label class="sm-card-option sm-card-option--white"
           data-action="click->smart-match-quiz#selectCard"
           data-select-mode="multiple">
      <input type="checkbox" name="giving_inspiration[]" value="values_aligned"
             class="sr-only" data-smart-match-quiz-target="causeCheckbox" />
      <span class="text-base font-bold text-center">Giving in alignment with my values</span>
      <%= inline_svg_tag "smart_match/family.svg", class: "w-20 h-20 mt-2 text-blue-dark", aria_hidden: "true" %>
    </label>

  </div>

  <div class="sm-selection-hint mt-5 rounded-lg px-5 py-3 text-sm font-medium text-blue-dark text-center" style="background-color: #e2ecf7;">
    Your answers help us identify donation opportunities that best match your preferences.
  </div>
<% end %>
