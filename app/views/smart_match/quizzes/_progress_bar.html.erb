<div class="flex gap-2" role="progressbar" aria-valuenow="<%= step %>" aria-valuemin="1" aria-valuemax="<%= total_steps %>">
  <% (1..4).each do |seg| %>
    <%
      section_steps = section_map.select { |_, v| v[:number] == seg }.keys.sort
      fill_pct = if section_steps.empty? || seg > current_section_number
        0
      elsif seg < current_section_number
        100
      else
        (section_steps.count { |s| s <= step }.to_f / section_steps.size * 100).round
      end
    %>
    <div class="sm-wizard__progress-segment flex-1"
         style="background: linear-gradient(to right, #113C7B <%= fill_pct %>%, #D3DCE6 <%= fill_pct %>%)">
    </div>
  <% end %>
</div>
