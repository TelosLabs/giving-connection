<%
  primary_causes = [
    ["Hunger & Food Security", "hunger_food_security.svg"],
    ["Housing & Homelessness", "housing_homelessness.svg"],
    ["Mental Health", "mental_health.svg"],
    ["Disability Services", "disability_services.svg"],
    ["Health", "health.svg"],
    ["Employment", "employment.svg"],
    ["Justice & Legal Services", "justice_legal_services.svg"],
    ["Children & Family Services", "children_family_services.svg"],
    ["Transportation", "transportation.svg"],
    ["LGBTQ+", "lgbtq+.svg"],
    ["Veteran & Military", "veteran_military.svg"],
    ["Financial Assistance", nil]
  ]

  accordion_causes = [
    ["Advocacy", "advocacy.svg"],
    ["Animals", "animals.svg"],
    ["Arts & Culture", "arts_culture.svg"],
    ["Clothing & Living Essentials", "clothing_living_essentials.svg"],
    ["Community & Economic Development", "community_economic_development.svg"],
    ["Drug & Alcohol Treatment", "drug_alcohol_treatment.svg"],
    ["Education", "education.svg"],
    ["Emergency & Safety", "emergency_safety.svg"],
    ["Faith-Based", "faith_based.svg"],
    ["Human & Social Services", "human_social_services.svg"],
    ["Immigrant & Refugee", "immigrant_refugee.svg"],
    ["Inmate & Formerly Incarcerated", "inmate_formerly_incarcerated.svg"],
    ["International", "international.svg"],
    ["Media & Broadcasting", "media_broadcasting.svg"],
    ["Philanthropy", "philanthropy.svg"],
    ["Race & Ethnicity", "race_ethnicity.svg"],
    ["Research & Public Policy", "research_public_policy.svg"],
    ["Science & Technology", "science_technology.svg"],
    ["Seniors", "seniors.svg"],
    ["Social Sciences", "social_sciences.svg"],
    ["Sports & Recreation", "sports_recreation.svg"],
    ["Youth Development", "youth_development.svg"]
  ]

  selected_causes = Array(session[:smart_match_causes])
%>

<%= form_with url: smart_match_quiz_path, method: :put, id: "quiz-form",
              data: { smart_match_quiz_target: "form" } do |f| %>

  <%# Primary causes: icon card grid (desktop) %>
  <div class="hidden sm:grid sm:grid-cols-3 md:grid-cols-4 gap-4 mt-4" data-card-group="causes">
    <% primary_causes.each do |cause_name, icon_file| %>
      <label class="sm-card-option <%= 'selected' if selected_causes.include?(cause_name) %>"
             data-action="click->smart-match-quiz#selectCard"
             data-select-mode="multiple">
        <input type="checkbox"
               name="causes[]"
               value="<%= cause_name %>"
               class="sr-only"
               <%= "checked" if selected_causes.include?(cause_name) %>
               data-smart-match-quiz-target="causeCheckbox" />
        <% if icon_file %>
          <%= image_tag "causes_categories/#{icon_file}", class: "w-10 h-10", alt: "", "aria-hidden": "true" %>
        <% else %>
          <svg class="w-10 h-10" fill="none" viewBox="0 0 24 24" stroke="#113C7B" stroke-width="1.5" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
        <% end %>
        <span class="text-sm font-semibold leading-tight text-gray-2"><%= cause_name %></span>
      </label>
    <% end %>
  </div>

  <%# Mobile: list view %>
  <div class="flex flex-col gap-3 mt-4 sm:hidden" data-card-group="causes-mobile">
    <% primary_causes.each do |cause_name, icon_file| %>
      <label class="sm-card-option--list <%= 'selected' if selected_causes.include?(cause_name) %>"
             data-action="click->smart-match-quiz#selectCard"
             data-select-mode="multiple">
        <input type="checkbox"
               name="causes[]"
               value="<%= cause_name %>"
               class="sr-only"
               <%= "checked" if selected_causes.include?(cause_name) %>
               data-smart-match-quiz-target="causeCheckbox" />
        <div class="flex items-center gap-3">
          <% if icon_file %>
            <%= image_tag "causes_categories/#{icon_file}", class: "flex-shrink-0 w-8 h-8", alt: "", "aria-hidden": "true" %>
          <% else %>
            <svg class="flex-shrink-0 w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="#113C7B" stroke-width="1.5" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          <% end %>
          <span class="text-sm font-semibold text-gray-2"><%= cause_name %></span>
        </div>
        <div class="flex-shrink-0 w-5 h-5 border-2 rounded border-gray-5 flex items-center justify-center">
          <svg class="w-3 h-3 text-blue-medium check-icon <%= 'hidden' unless selected_causes.include?(cause_name) %>" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
          </svg>
        </div>
      </label>
    <% end %>
  </div>

  <%# Accordion: more causes %>
  <div class="mt-6">
    <button type="button"
            class="flex items-center gap-2 text-sm font-semibold cursor-pointer text-blue-dark hover:text-blue-medium"
            data-action="click->smart-match-quiz#toggleAccordion"
            data-smart-match-quiz-target="accordion">
      <span>Not finding a cause? More options here.</span>
      <svg class="w-4 h-4 transition-transform duration-200" data-smart-match-quiz-target="accordionIcon" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
      </svg>
    </button>

    <div class="sm-category-accordion" data-smart-match-quiz-target="accordionContent">
      <div class="grid grid-cols-1 gap-2 pt-4 sm:grid-cols-2 md:grid-cols-3">
        <% accordion_causes.each do |cause_name, icon_file| %>
          <label class="flex items-center gap-3 p-3 text-sm border-2 rounded-lg cursor-pointer border-gray-6 transition-colors pill-label hover:border-blue-medium"
                 data-action="click->smart-match-quiz#toggleCause">
            <input type="checkbox"
                   name="causes[]"
                   value="<%= cause_name %>"
                   class="sr-only pill"
                   <%= "checked" if selected_causes.include?(cause_name) %>
                   data-smart-match-quiz-target="causeCheckbox" />
            <%= image_tag "causes_categories/#{icon_file}", class: "flex-shrink-0 w-5 h-5", alt: "", "aria-hidden": "true" %>
            <span class="text-gray-2"><%= cause_name %></span>
          </label>
        <% end %>
      </div>
    </div>
  </div>
<% end %>
