<%# Smart Match landing page %>

<%# ── Hero ─────────────────────────────────────────────────────────────── %>
<section class="sm-gradient-hero py-16 px-6 sm:py-12">
  <div class="max-w-3xl mx-auto text-center">
    <h1 class="text-3xl font-bold text-white sm:text-[40px] sm:leading-tight pb-6">
      Welcome to Smart Match
    </h1>
    <p class="text-base text-white sm:text-xl leading-relaxed max-w-2xl mx-auto">
      A Giving Connection feature designed to help you quickly identify nonprofits
      aligned with your goals, situation, and location without the overwhelm of
      endless searching.
    </p>
  </div>
</section>

<%# ── Features ─────────────────────────────────────────────────────────── %>
<section class="py-16 px-6 bg-white">
  <div class="max-w-4xl mx-auto">

    <%# Illustration %>
    <div class="flex justify-center pb-12">
      <%= image_tag "cloud-laptop.svg",
            class: "w-1/3 max-w-md h-auto",
            alt: "Person browsing nonprofits" %>
    </div>

    <%# Three feature highlights %>
    <div class="flex flex-col gap-10 sm:flex-row sm:gap-8 justify-center pb-12">

      <%# Feature 1 — Clock %>
      <div class="flex flex-col items-center text-center max-w-xs mx-auto">
        <%= inline_svg_tag "smart_match/crono.svg", class: "w-12 h-12 mb-4 text-red-40", alt: "", "aria-hidden": "true" %>
        <h3 class="text-lg font-bold text-blue-dark sm:text-2xl">
          Takes 3-5 minutes
        </h3>
      </div>

      <%# Feature 2 — Heart-hand %>
      <div class="flex flex-col items-center text-center max-w-xs mx-auto">
        <%= inline_svg_tag "hand-heart.svg", class: "w-12 h-12 mb-4 text-red-400", alt: "", "aria-hidden": "true" %>
        <h3 class="text-lg font-bold text-blue-dark sm:text-2xl">
          Personalized nonprofit matches
        </h3>
      </div>

      <%# Feature 3 — User-heart %>
      <div class="flex flex-col items-center text-center max-w-xs mx-auto">
        <%= inline_svg_tag "user-heart.svg", class: "w-12 h-12 mb-4 text-red-400", alt: "", "aria-hidden": "true" %>
        <h3 class="text-lg font-bold text-blue-dark sm:text-2xl">
          Based on your needs and preferences
        </h3>
      </div>
    </div>

    <%# Description %>
    <p class="text-base sm:text-lg font-medium text-gray-2 text-center max-w-2xl mx-auto pb-10 leading-relaxed">
      We'll ask you a few simple questions about what you're looking for. Based on
      your responses, we'll recommend nonprofits that are most relevant to you.
    </p>

    <%# CTA %>
    <div class="text-center pb-4">
      <p class="text-lg font-bold text-gray-2 sm:text-2xl font-[Poppins] pb-8">
        Ready to find the nonprofit that's right for you?
      </p>

      <%= link_to "START",
            smart_match_quiz_path,
            class: "inline-block px-12 py-4 text-lg font-bold tracking-wider text-blue-dark uppercase rounded-md bg-seafoam hover:bg-seafoam-light transition-colors",
            data: { test_id: "smart_match_start_btn" } %>
    </div>
  </div>
</section>
