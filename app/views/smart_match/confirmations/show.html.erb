<section class="flex flex-col min-h-screen bg-white sm-wizard">

  <%# Main content %>
  <div class="flex-1 flex flex-col items-center justify-center px-4 py-12 sm:px-0">
    <div class="w-full sm:max-w-xl text-center">

      <h1 class="text-3xl sm:text-4xl font-bold text-blue-dark">Ready to see your results?</h1>

      <p class="mt-3 text-base sm:text-lg text-gray-3">
        You've completed <strong>Smart Match</strong>!<br>
        Based on your responses, we're ready to show you nonprofit<br class="hidden sm:inline">
        organizations that align with your interests and preferences.
      </p>

      <%# Illustration %>
      <div class="flex justify-center my-8">
        <%= inline_svg_tag "smart_match/achievements.svg",
              class: "w-56 h-56 sm:w-72 sm:h-72",
              aria_hidden: "true" %>
      </div>

      <%# Info box %>
      <div class="rounded-xl px-6 py-4 text-sm sm:text-base text-gray-3 text-center" style="background-color: #e2ecf7;">
        This is your chance to go back and <strong>review</strong> or <strong>update</strong> your answers.
        Once you submit, you'll need to retake the questionnaire to make changes.
      </div>

    </div>
  </div>

  <%# Sticky footer — matches wizard footer style %>
  <div class="sm-wizard__footer">
    <div class="flex items-center justify-between w-full px-4 sm:w-3/4 sm:mx-auto sm:px-0">
      <%= link_to "Go Back",
            smart_match_quiz_path,
            class: "text-base font-semibold cursor-pointer text-blue-dark hover:underline" %>

      <%= link_to "SUBMIT",
            smart_match_result_path,
            class: "px-10 py-3 text-sm font-bold tracking-wider text-white uppercase rounded-md bg-blue-dark hover:bg-blue-medium transition-colors" %>
    </div>
  </div>

</section>
